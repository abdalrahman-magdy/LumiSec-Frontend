# Backend API root (no trailing slash). Switch this URL when moving environments:
# Local:   http://localhost:3000
# Online:  https://your-production-api.example.com
REACT_APP_API_BASE_URL=http://localhost:3000

# Phishing mock fallback — set to false for real API integration (recommended for staging/production)
REACT_APP_PHISHING_MOCK_FALLBACK=false

# Optional: show localStorage role switcher in Phishing header (dev only)
REACT_APP_PHISHING_DEV_ROLE_SWITCHER=false
