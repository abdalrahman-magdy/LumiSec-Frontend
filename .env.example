# Backend API root (no trailing slash). Switch when moving environments:
# Local:   http://localhost:3000
# Online:  https://api.yourdomain.com
REACT_APP_API_BASE_URL=http://localhost:3000

# Phishing mock fallback — set to false for real API (recommended)
REACT_APP_PHISHING_MOCK_FALLBACK=false

# Optional: show localStorage role switcher in Phishing header (dev only)
REACT_APP_PHISHING_DEV_ROLE_SWITCHER=false

# React dev server port — use 3001 when backend runs on 3000
PORT=3001
